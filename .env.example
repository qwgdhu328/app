# BenessereBot — Environment Variables Template
#
# Copy this file to `.env` and fill in your real values.
# NEVER commit a real `.env` file with actual keys to git.
# `.env` is included in .gitignore.
#
# How EXPO_PUBLIC_* works:
# - Expo SDK 49+ exposes any var prefixed with `EXPO_PUBLIC_` to the client at build time.
# - Inside the app, access via `process.env.EXPO_PUBLIC_*`.
# - These vars are inlined in the JS bundle, so they are NOT secret for production.
# - For a privacy-sensitive deployment, route requests through a backend proxy.

# OpenRouter API key (https://openrouter.ai/keys)
EXPO_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default model. Use openrouter/free for free models, or set a specific one.
EXPO_PUBLIC_OPENROUTER_MODEL=openrouter/free
